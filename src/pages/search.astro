---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import PageIntro from "../components/PageIntro.astro";
import {
  excerptText,
  publishedEntries,
  sortEntries,
  taxonomyLabel,
  toPlainText
} from "../lib/content";

const notes = sortEntries(publishedEntries(await getCollection("notes")));
const writing = sortEntries(publishedEntries(await getCollection("writing")));
const projects = sortEntries(publishedEntries(await getCollection("projects")));

const searchEntries = [
  ...notes.map((entry) => ({
    kind: "notes",
    kindLabel: "Notes",
    title: entry.data.title,
    description: entry.data.description,
    tags: entry.data.tags,
    href: `/notes/${entry.slug}/`,
    taxonomy: taxonomyLabel(entry.data.topic, entry.data.subtopic),
    snippet: excerptText(entry.body || entry.data.description),
    searchText: [
      entry.data.title,
      entry.data.description,
      entry.data.topic,
      entry.data.subtopic,
      ...entry.data.tags,
      toPlainText(entry.body)
    ]
      .filter(Boolean)
      .join("\n")
  })),
  ...writing.map((entry) => ({
    kind: "writing",
    kindLabel: "Writing",
    title: entry.data.title,
    description: entry.data.description,
    tags: entry.data.tags,
    href: `/writing/${entry.slug}/`,
    taxonomy: taxonomyLabel(entry.data.type, entry.data.subtype),
    snippet: excerptText(entry.body || entry.data.description),
    searchText: [
      entry.data.title,
      entry.data.description,
      entry.data.type,
      entry.data.subtype,
      ...entry.data.tags,
      toPlainText(entry.body)
    ]
      .filter(Boolean)
      .join("\n")
  })),
  ...projects.map((entry) => ({
    kind: "projects",
    kindLabel: "Projects",
    title: entry.data.title,
    description: entry.data.description,
    tags: entry.data.tags,
    href: `/projects/${entry.slug}/`,
    taxonomy: taxonomyLabel(entry.data.category, entry.data.subcategory),
    snippet: excerptText(entry.body || entry.data.description),
    searchText: [
      entry.data.title,
      entry.data.description,
      entry.data.category,
      entry.data.subcategory,
      entry.data.status,
      ...entry.data.tags,
      toPlainText(entry.body)
    ]
      .filter(Boolean)
      .join("\n")
  }))
];
const searchIndexJson = JSON.stringify(searchEntries).replace(/</g, "\\u003c");
---

<Layout title="Pineappler | Search" description="按标题、描述、标签与正文摘要检索站内内容。">
  <PageIntro
    eyebrow="Search"
    title="Search the archive"
    intro="支持按标题、描述、标签与正文摘要检索 Notes、Writing 和 Projects。"
  />

  <section class="section-block search-shell">
    <label class="search-label" for="site-search-input">关键词</label>
    <input
      id="site-search-input"
      class="search-input"
      type="search"
      placeholder="例如：生命叙事、workflow、游戏研究"
      autocomplete="off"
      data-search-input
    />
    <p class="search-summary" data-search-summary>输入关键词后开始检索。</p>
    <div class="search-results" data-search-results></div>
  </section>

  <script id="search-index" type="application/json" set:html={searchIndexJson}></script>
  <script type="module" src="/search.js"></script>
</Layout>
