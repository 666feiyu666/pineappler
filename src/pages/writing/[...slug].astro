---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import TagList from "../../components/TagList.astro";
import { formatDate, publishedEntries, taxonomyLabel } from "../../lib/content";

export async function getStaticPaths() {
  const entries = publishedEntries(await getCollection("writing"));
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Writing`} description={entry.data.description}>
  <article class="content-block">
    <p class="entry-date">{taxonomyLabel(entry.data.type, entry.data.subtype)}</p>
    <h1 class="page-title">{entry.data.title}</h1>
    <p class="page-summary">{entry.data.description}</p>
    <div class="detail-actions">
      <span class="entry-date">{formatDate(entry.data.date)}</span>
    </div>
    <TagList tags={entry.data.tags} />
    <div class="prose-block">
      <Content />
    </div>
  </article>
</Layout>
