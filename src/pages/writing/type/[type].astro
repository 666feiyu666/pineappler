---
import { getCollection } from "astro:content";
import EntryCard from "../../../components/EntryCard.astro";
import FilterStrip from "../../../components/FilterStrip.astro";
import Layout from "../../../components/Layout.astro";
import PageIntro from "../../../components/PageIntro.astro";
import {
  publishedEntries,
  sortEntries,
  taxonomyLabel,
  toParam,
  uniqueNonEmpty,
  uniqueValues
} from "../../../lib/content";

const allEntries = sortEntries(publishedEntries(await getCollection("writing")));
const types = uniqueValues(allEntries.map((entry) => entry.data.type));

export async function getStaticPaths() {
  const entries = sortEntries(publishedEntries(await getCollection("writing")));
  const types = uniqueValues(entries.map((entry) => entry.data.type));
  return types.map((type) => ({
    params: { type: toParam(type) },
    props: {
      type,
      entries: entries.filter((entry) => entry.data.type === type)
    }
  }));
}

const { type, entries } = Astro.props;
const subtypes = uniqueNonEmpty(entries.map((entry) => entry.data.subtype));
---

<Layout title={`Pineappler | ${type}`} description={`${type} 类型下的 writing 条目。`}>
  <PageIntro
    eyebrow="Writing"
    title={type}
    intro={subtypes.length > 0 ? `当前类型下包含 ${subtypes.length} 个子主题。` : undefined}
  />
  <FilterStrip
    items={[
      { href: "/writing", label: "全部" },
      ...types.map((item) => ({
        href: `/writing/type/${toParam(item)}/`,
        label: item,
        active: item === type
      }))
    ]}
  />
  {subtypes.length > 0 && (
    <FilterStrip
      items={[
        { href: `/writing/type/${toParam(type)}/`, label: "全部子主题", active: true },
        ...subtypes.map((item) => ({
          href: `/writing/type/${toParam(type)}/${toParam(item)}/`,
          label: item
        }))
      ]}
    />
  )}

  <section class="section-block">
    <div class="entry-grid">
      {entries.map((entry) => (
        <EntryCard
          href={`/writing/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          meta={[taxonomyLabel(entry.data.type, entry.data.subtype)]}
          badge={entry.data.format === "pdf" ? "PDF" : undefined}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</Layout>
