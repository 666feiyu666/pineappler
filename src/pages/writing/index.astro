---
import { getCollection } from "astro:content";
import EntryCard from "../../components/EntryCard.astro";
import FilterStrip from "../../components/FilterStrip.astro";
import Layout from "../../components/Layout.astro";
import PageIntro from "../../components/PageIntro.astro";
import {
  orderedTaxonomyValues,
  publishedEntries,
  sortEntries,
  toParam
} from "../../lib/content";

const entries = sortEntries(publishedEntries(await getCollection("writing")));
const types = orderedTaxonomyValues(entries.map((entry) => entry.data.type), "writingTypes");
---

<Layout title="Pineappler | Writing" description="按最新时间排列的 Markdown 文章列表。">
  <PageIntro eyebrow="Writing" title="Latest writing" />
  <FilterStrip
    items={[
      { href: "/writing", label: "全部", active: true },
      ...types.map((type) => ({
        href: `/writing/type/${toParam(type)}/`,
        label: type
      }))
    ]}
  />

  <section class="section-block">
    <div class="entry-grid">
      {entries.map((entry) => (
        <EntryCard
          href={`/writing/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          meta={[entry.data.type]}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</Layout>
