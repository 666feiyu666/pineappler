---
import { getCollection } from "astro:content";
import EntryCard from "../../../components/EntryCard.astro";
import FilterStrip from "../../../components/FilterStrip.astro";
import Layout from "../../../components/Layout.astro";
import PageIntro from "../../../components/PageIntro.astro";
import {
  orderedTaxonomyValues,
  publishedEntries,
  sortEntries,
  toParam
} from "../../../lib/content";

const allNotes = sortEntries(publishedEntries(await getCollection("notes")));
const topics = orderedTaxonomyValues(allNotes.map((entry) => entry.data.topic), "notesTopics");

export async function getStaticPaths() {
  const notes = sortEntries(publishedEntries(await getCollection("notes")));
  const topics = orderedTaxonomyValues(notes.map((entry) => entry.data.topic), "notesTopics");
  return topics.map((topic) => ({
    params: { topic: toParam(topic) },
    props: {
      topic,
      notes: notes.filter((entry) => entry.data.topic === topic)
    }
  }));
}

const { topic, notes } = Astro.props;
---

<Layout title={`Pineappler | ${topic}`} description={`${topic} 主题下的笔记。`}>
  <PageIntro eyebrow="Notes" title={topic} />
  <FilterStrip
    items={[
      { href: "/notes", label: "全部" },
      ...topics.map((item) => ({
        href: `/notes/topic/${toParam(item)}/`,
        label: item,
        active: item === topic
      }))
    ]}
  />
  <section class="section-block">
    <div class="entry-grid">
      {notes.map((entry) => (
        <EntryCard
          href={`/notes/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.uploadDate ?? entry.data.date}
          meta={[entry.data.topic]}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</Layout>
