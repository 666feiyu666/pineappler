---
import { getCollection } from "astro:content";
import EntryCard from "../../components/EntryCard.astro";
import FilterStrip from "../../components/FilterStrip.astro";
import Layout from "../../components/Layout.astro";
import PageIntro from "../../components/PageIntro.astro";
import {
  orderedTaxonomyValues,
  publishedEntries,
  sortEntries,
  taxonomyLabel,
  toParam
} from "../../lib/content";

const notes = sortEntries(publishedEntries(await getCollection("notes")));
const topics = orderedTaxonomyValues(notes.map((entry) => entry.data.topic), "notesTopics");
---

<Layout title="Pineappler | Notes" description="按最新时间排列的笔记列表。">
  <PageIntro eyebrow="Notes" title="Latest notes" />
  <FilterStrip
    items={[
      { href: "/notes", label: "全部", active: true },
      ...topics.map((topic) => ({
        href: `/notes/topic/${toParam(topic)}/`,
        label: topic
      }))
    ]}
  />

  <section class="section-block">
    <div class="entry-grid">
      {notes.map((entry) => (
        <EntryCard
          href={`/notes/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.uploadDate ?? entry.data.date}
          meta={[taxonomyLabel(entry.data.topic, entry.data.subtopic)]}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</Layout>
