---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import TagList from "../../components/TagList.astro";
import { formatDate, publishedEntries, taxonomyLabel } from "../../lib/content";

export async function getStaticPaths() {
  const notes = publishedEntries(await getCollection("notes"));
  return notes.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Notes`} description={entry.data.description}>
  <article class="content-block">
    <p class="entry-date">
      {taxonomyLabel(entry.data.topic, entry.data.subtopic)} · {formatDate(entry.data.uploadDate ?? entry.data.date)}
    </p>
    <h1 class="page-title">{entry.data.title}</h1>
    <p class="page-summary">{entry.data.description}</p>
    <TagList tags={entry.data.tags} />
    <div class="prose-block">
      <Content />
    </div>
  </article>
</Layout>
