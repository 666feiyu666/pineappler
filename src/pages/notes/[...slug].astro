---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import TagList from "../../components/TagList.astro";
import { formatDate, publishedEntries } from "../../lib/content";

export async function getStaticPaths() {
  const notes = publishedEntries(await getCollection("notes"));
  return notes.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Notes`} description={entry.data.description}>
  <article class="content-block detail-article">
    <div class="detail-hero">
      <p class="detail-kicker">
      {entry.data.topic} · {formatDate(entry.data.uploadDate ?? entry.data.date)}
      </p>
      <h1 class="page-title">{entry.data.title}</h1>
      <p class="page-summary">{entry.data.description}</p>
      <TagList tags={entry.data.tags} />
    </div>
    <div class="prose-block">
      <Content />
    </div>
  </article>
</Layout>
