---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import TagList from "../../components/TagList.astro";
import {
  formatDate,
  formatExternalLinkLabel,
  publishedEntries,
  taxonomyLabel
} from "../../lib/content";

export async function getStaticPaths() {
  const entries = publishedEntries(await getCollection("projects"));
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Projects`} description={entry.data.description}>
  <article class="content-block">
    <p class="entry-date">{formatDate(entry.data.date)}</p>
    <h1 class="page-title">{entry.data.title}</h1>
    <p class="page-summary">{entry.data.description}</p>
    {entry.data.imagePath && (
      <figure class="project-hero">
        <img src={entry.data.imagePath} alt={entry.data.imageAlt || entry.data.title} loading="eager" />
      </figure>
    )}
    <div class="meta-grid">
      <div>
        <span>Category</span>
        <strong>{taxonomyLabel(entry.data.category, entry.data.subcategory)}</strong>
      </div>
      <div>
        <span>Status</span>
        <strong>{entry.data.status}</strong>
      </div>
      {entry.data.link && (
        <div>
          <span>Link</span>
          <a class="content-link" href={entry.data.link} target="_blank" rel="noreferrer">
            {formatExternalLinkLabel(entry.data.link)}
          </a>
        </div>
      )}
    </div>
    <TagList tags={entry.data.tags} />
    <div class="prose-block">
      <Content />
    </div>
  </article>
</Layout>
