---
import { formatDate } from "../lib/content";
import TagList from "./TagList.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  meta?: string[];
  tags?: string[];
  badge?: string;
  linkLabel?: string;
  externalLink?: string;
  externalLinkLabel?: string;
  imagePath?: string;
  imageAlt?: string;
}

const {
  href,
  title,
  description,
  date,
  meta = [],
  tags = [],
  badge,
  linkLabel = "Open",
  externalLink,
  externalLinkLabel = "Visit project",
  imagePath,
  imageAlt
} = Astro.props;

const metaText = meta.filter(Boolean).join(" · ");
---

<article class="entry-card">
  {imagePath && (
    <a class="entry-card-media" href={href} aria-hidden="true" tabindex="-1">
      <img src={imagePath} alt={imageAlt || title} loading="lazy" />
    </a>
  )}
  <div class="card-topline">
    <p class="card-meta">{metaText || formatDate(date)}</p>
    {badge && <span class="card-badge">{badge}</span>}
  </div>
  <h3>
    <a href={href}>{title}</a>
  </h3>
  <p>{description}</p>
  {externalLink && (
    <a class="external-link" href={externalLink} target="_blank" rel="noreferrer">
      {externalLinkLabel}
    </a>
  )}
  <TagList tags={tags} />
  <div class="card-footer">
    <span class="entry-date">{formatDate(date)}</span>
    <span class="card-cta">{linkLabel}</span>
  </div>
</article>
